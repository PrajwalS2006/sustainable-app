# Copy to backend/.env and adjust values.
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/sustainable_app
JWT_SECRET=change_this_to_a_long_random_string_in_production

# --- SDG7 Blockchain (MovementRegistry) ---
# Set BLOCKCHAIN_MODE=ethereum and provide RPC/private key/contract address.
# For local dev without a deployed contract you can use BLOCKCHAIN_MODE=mock.
BLOCKCHAIN_MODE=mock
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
BLOCKCHAIN_PRIVATE_KEY=change_me
BLOCKCHAIN_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
# How many confirmations to wait before marking movement as verified
BLOCKCHAIN_CONFIRMATIONS=1
