# Copy to frontend/.env.local for local development (optional).
#
# Web: defaults to http://localhost:5000/api
# Android emulator: app uses http://10.0.2.2:5000/api automatically (no env needed).
# Physical device: set your PC's LAN IP before `npm run build`:
#   REACT_APP_API_URL=http://192.168.1.XXX:5000/api
REACT_APP_API_URL=http://localhost:5000/api
